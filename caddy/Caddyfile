# ─────────────────────────────────────────────────────────────────────────────
# Linux Traffic Shaper — Caddyfile
#
# Plain HTTP on port 80 — sufficient for a local LAN tool.
# network_mode: host means Caddy binds on ALL host IPs automatically.
# ─────────────────────────────────────────────────────────────────────────────

:80 {
    # Proxy REST API to FastAPI backend
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # Proxy WebSocket stats stream to FastAPI backend
    handle /ws/* {
        reverse_proxy localhost:8000
    }

    # Serve the React SPA with fallback for client-side routing
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
